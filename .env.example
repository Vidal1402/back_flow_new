APP_ENV=local
APP_URL=http://localhost:8000
APP_KEY=troque-esta-chave-por-uma-chave-segura
JWT_TTL=3600

# MongoDB Atlas (URI completa; pode incluir o nome da base no path após o host)
# Exemplo: mongodb+srv://USER:PASSWORD@cluster.mongodb.net/nome_da_base?appName=united-flow
MONGODB_URI=
# Opcional: se a URI não tiver path com o nome da base, defina aqui (padrão: united_flow)
MONGODB_DATABASE=united_flow
# Rode criação de índices no startup (normalmente false em produção para reduzir latência).
MONGO_ENSURE_INDEXES=false

# Bootstrap de admin (opcional, recomendado no primeiro deploy):
# Se ADMIN_EMAIL e ADMIN_PASSWORD estiverem preenchidos e o email não existir,
# um usuário admin será criado automaticamente na inicialização.
# Além disso, no primeiro POST /api/auth/login com essas credenciais, o admin
# também é criado automaticamente caso o banco esteja vazio.
ADMIN_NAME=Administrador
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Use true temporariamente para resetar senha/role do ADMIN_EMAIL no startup.
# Depois volte para false.
ADMIN_FORCE_RESET_PASSWORD=false

# Railway — definir no painel (não no .env local). O deploy usa Dockerfile (PHP escuta em $PORT).
# Garante que "Networking → Target port" = valor de PORT (ex. 8080).
