APP_ENV=local
APP_URL=http://localhost:8000
APP_KEY=troque-esta-chave-por-uma-chave-segura
JWT_TTL=3600
# false = mais rápido (usa claims do JWT e cache do token); true = consulta usuário no banco a cada request
AUTH_LOOKUP_USER_DB=false

# Em produção, defina DEBUG=1 só para depurar (expõe detalhes de erro no JSON).
# DEBUG=0
# Loga body bruto de POST /api/marketing-metrics (use temporariamente para diagnóstico)
# MARKETING_METRICS_DEBUG_LOG=false

# Origens permitidas para o front (separadas por vírgula). Se vazio, usa * (qualquer origem).
# Ex.: CORS_ORIGINS=http://localhost:8082,http://localhost:5173,https://seu-front.vercel.app
# CORS_ORIGINS=

# MongoDB
# Exemplo Atlas:
# MONGODB_URI=mongodb+srv://usuario:senha@cluster0.xxxxx.mongodb.net/united_flow?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://usuario:senha@cluster0.xxxxx.mongodb.net/united_flow?retryWrites=true&w=majority

# Opcional: força nome do DB mesmo que a URI já tenha path
MONGODB_DATABASE=united_flow

# Seed opcional de admin inicial (executa 1x se o email nao existir)
# SEED_ADMIN_NAME=Administrador
# SEED_ADMIN_EMAIL=admin@seudominio.com
# SEED_ADMIN_PASSWORD=troque-essa-senha
